---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'OT/ICS security advisory services for critical infrastructure operators.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | Rawson Consulting</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans antialiased">

    <!-- Nav -->
    <header class="fixed top-0 inset-x-0 z-50 border-b border-slate-800 bg-slate-950/90 backdrop-blur-sm">
      <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
          <img src="/rawson-consulting-logo.svg" alt="Rawson Consulting" class="h-9 w-auto" />
          <span class="text-white font-semibold tracking-tight text-lg">Rawson Consulting</span>
        </a>
        <div class="flex items-center gap-8 text-sm font-medium">
          <a href="/" class={`transition-colors ${currentPath === '/' ? 'text-sky-400' : 'text-slate-400 hover:text-white'}`}>Home</a>
          <a href="/about" class={`transition-colors ${currentPath === '/about' ? 'text-sky-400' : 'text-slate-400 hover:text-white'}`}>About</a>
          <a href="/contact" class="px-4 py-1.5 rounded bg-sky-600 hover:bg-sky-500 text-white transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <!-- Page content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-24 border-t border-slate-800 py-10 text-center text-slate-500 text-sm">
      <div class="max-w-5xl mx-auto px-6">
        <img src="/rawson-consulting-logo.svg" alt="Rawson Consulting" class="h-14 w-auto mx-auto mb-4 opacity-80" />
        <p class="font-medium text-slate-300 mb-1">Rawson Consulting LLC</p>
        <p>Las Vegas, NV &nbsp;·&nbsp; Licensed in Nevada</p>
        <p class="mt-4">&copy; {new Date().getFullYear()} Rawson Consulting LLC. All rights reserved.</p>
      </div>
    </footer>

  </body>
</html>
