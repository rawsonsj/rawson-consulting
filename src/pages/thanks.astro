---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Message Sent" description="Thank you for reaching out to Rawson Consulting.">
  <section class="max-w-5xl mx-auto px-6 py-32 text-center">
    <div class="text-sky-400 text-5xl mb-6">✓</div>
    <h1 class="text-4xl font-bold text-white mb-4">Message Received</h1>
    <p class="text-xl text-slate-300 max-w-md mx-auto mb-10">
      Thanks for reaching out. You'll hear back within 1–2 business days.
    </p>
    <a href="/" class="inline-block px-6 py-3 rounded-lg border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white font-semibold transition-colors">
      Back to Home
    </a>
  </section>
</Layout>
