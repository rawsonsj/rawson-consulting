---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Reach out to Rawson Consulting to discuss your OT/ICS security needs.">

  <section class="max-w-5xl mx-auto px-6 py-20">

    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-slate-700 bg-slate-900/50 text-slate-400 text-xs font-medium tracking-wider uppercase mb-6">
        Availability
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">Not Currently Available</h1>
      <p class="text-xl text-slate-300 leading-relaxed mb-8">
        Rawson Consulting is not accepting new engagements at this time.
      </p>
      <p class="text-slate-400 leading-relaxed">
        Check back in the future — availability will be updated here when new engagements open up.
      </p>
    </div>

  </section>

</Layout>
